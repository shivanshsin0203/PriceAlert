# ── Server env (see ARCHITECTURE.md §15). Copy to .env and fill in as features land. ──
NODE_ENV=development
PORT=4000

# DATABASE_URL=postgres://user:pass@host/db          # Neon
# REDIS_URL=redis://localhost:6379

# Auth (required): JWT_SECRET must be IDENTICAL to the one in client/.env.local.
# Generate: openssl rand -hex 32 (JWT) / openssl rand -hex 24 (internal)
# JWT_SECRET=change-me-min-32-chars-................
# INTERNAL_API_SECRET=change-me-min-16-chars

# TELEGRAM_BOT_TOKEN=
# Transport (ARCHITECTURE.md §19): polling = local dev · webhook = production ·
# off = REQUIRED local default after deploy (polling with the prod token deletes the prod webhook!)
# TELEGRAM_MODE=polling
# TELEGRAM_WEBHOOK_SECRET=                            # required (>=16 chars) when TELEGRAM_MODE=webhook
# TELEGRAM_BOT_USERNAME=Pricealert_devbot            # for t.me deep-link account linking
# DEEPSEEK_API_KEY=
# PUBLIC_BASE_URL=https://your-vm-domain
# FINNHUB_API_KEY=
# TWELVEDATA_API_KEY=

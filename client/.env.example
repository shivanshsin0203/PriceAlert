# ── Client env (see ARCHITECTURE.md §15). Copy to .env.local. ──
# Express API base (server-to-server from the BFF)
EXPRESS_API_URL=http://localhost:4000
# Public origin of THIS Next app (Google redirects back to ${APP_URL}/api/auth/callback)
APP_URL=http://localhost:3000

# Shared secrets — MUST match server/.env exactly.
# Generate: openssl rand -hex 32 (JWT) / openssl rand -hex 24 (internal)
INTERNAL_API_SECRET=change-me-min-16-chars
JWT_SECRET=change-me-min-32-chars-................

# Google OAuth (console.cloud.google.com → Credentials → OAuth client ID, type "Web").
# Authorized redirect URI: ${APP_URL}/api/auth/callback
# Empty = dev-fallback mode (no sign-in; dashboard acts as the server's DASHBOARD_CHAT_ID user).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
